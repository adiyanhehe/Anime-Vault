# Example environment variables for Anime Vault
# If you use the Vite proxy (default dev config), set VITE_ANFIRE_API_URL=/api

# API URL to call (use /api when proxying to localhost:3000)
VITE_ANFIRE_API_URL=/api

# Your AnFire API key (must match the server's API_KEY)
VITE_ANFIRE_API_KEY=your_api_key_here
