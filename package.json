{
  "name": "animevault",
  "private": true,
  "version": "0.2.52",
  "description": "The ultimate anime streaming experience",
  "author": "AnimeVault Team",
  "type": "module",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "generate-icons": "node scripts/generate-icons.js",
    "generate-dev-cert": "powershell -ExecutionPolicy Bypass -File scripts/generate-dev-cert.ps1",
    "clean": "rimraf release",
    "prebuild": "node -e \"try{require('child_process').execSync('taskkill /IM AnimeVault.exe /F',{stdio:'ignore'})}catch(e){console.log('No running instance')}\"",
    "electron:dev": "cross-env NODE_ENV=development concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:build": "npm run prebuild && npm run clean && cross-env NODE_OPTIONS=--max_old_space_size=8192 && npm run generate-icons && cross-env ELECTRON=1 && vite build && electron-builder --publish never",
    "predeploy": "npm run build",
    "deploy": "gh-pages -d dist",
    "bump-version": "npm version patch -m \"chore: bump version to %s\"",
    "android:build": "npm run android:sync && cd android && chmod +x gradlew && ./gradlew assembleRelease",
    "android:build:win": "npm run android:sync && cd android && set \"JAVA_HOME=D:\\jdk-21\\jdk-21.0.11\" && set \"PATH=%JAVA_HOME%\\bin;%PATH%\" && gradlew assembleRelease",
    "electron:release": "npm run generate-icons && cross-env ELECTRON=1 vite build && electron-builder --publish always",
    "electron:build:win": "npm run prebuild && npm run clean && npm run generate-icons && cross-env ELECTRON=1 && vite build && electron-builder --win --publish never",
    "electron:build:mac": "npm run generate-icons && cross-env ELECTRON=1 vite build && electron-builder --mac --publish never",
    "electron:build:linux": "npm run generate-icons && cross-env ELECTRON=1 vite build && electron-builder --linux --publish never",
    "android:sync": "npm run build && npx cap sync android",
    "android:ensure": "npx cap add android || echo 'Android already added'",
    "android:mobile": "npm run generate-icons && vite build --config vite.mobile.config.js && npx cap sync android && cd android && chmod +x gradlew && ./gradlew assembleRelease"
  },
  "build": {
    "appId": "com.animevault.app",
    "productName": "AnimeVault",
    "directories": {
      "output": "release"
    },
    "asar": true,
    "files": [
      "dist/**/*",
      "electron/**/*",
      "build/**/*"
    ],
    "npmRebuild": false,
    "extraMetadata": {
      "dependencies": {
        "bcryptjs": "2.4.3"
      }
    },
    "nsis": {
      "allowToChangeInstallationDirectory": true,
      "oneClick": false
    },
    "win": {
      "icon": "build/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "AnimeVault-Windows-${arch}.${ext}",
      "publisherName": "AnimeVault Dev",
      "forceCodeSigning": false,
      "signAndEditExecutable": false
    },

    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "hardenedRuntime": false,
      "gatekeeperAssess": false,
      "identity": null,
      "artifactName": "AnimeVault-macOS-${arch}.${ext}"
    },

    "linux": {
      "target": [
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "src/electron/.icon-ico/icon.png",
      "category": "AudioVideo",
      "maintainer": "AnimeVault Team",
      "artifactName": "AnimeVault-Linux-${arch}.${ext}"
    },
    "publish": [
      {
        "provider": "github",
        "releaseType": "release"
      }
    ]
  },
  "dependencies": {
    "@neondatabase/auth": "^0.3.0-beta",
    "@neondatabase/serverless": "^1.1.0",
    "@noriginmedia/norigin-spatial-navigation": "^3.1.0",
    "@vidstack/react": "^1.12.13",
    "discord-rpc": "^4.0.1",
    "framer-motion": "^12.38.0",
    "hls.js": "^1.6.16",
    "lucide-react": "^1.16.0",
    "react": "^18.3.1",
    "axios": "^1.7.2",
    "graphql-request": "^6.1.0",
    "react-icons": "^5.6.0",
    "react-router-dom": "^6.30.1",
    "vidstack": "^1.12.13",
    "electron-updater": "^6.3.9",
    "@capacitor/core": "^6.2.1",
    "bcryptjs": "^2.4.3"
  },
  "devDependencies": {
    "@types/react-router-dom": "^5.3.3",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^8.2.2",
    "electron": "^42.3.0",
    "electron-builder": "24.13.2",
    "gh-pages": "^6.3.0",
    "vite": "^5.4.19",
    "cross-env": "^7.0.3",
    "wait-on": "^7.2.0",
    "rimraf": "^5.0.5",
    "@capacitor/android": "^6.2.1",
    "@capacitor/cli": "^6.2.1"
  },
  "engines": {
    "node": ">=22.12.0"
  }
}
