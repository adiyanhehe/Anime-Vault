{
  "name": "animevault",
  "private": true,
  "version": "0.2.21",
  "description": "The ultimate anime streaming experience",
  "author": "AnimeVault Team",
  "type": "module",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "generate-icons": "node scripts/generate-icons.js",
    "electron:dev": "cross-env NODE_ENV=development concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:build": "npm run generate-icons && cross-env ELECTRON=1 vite build && electron-builder --publish never",
    "predeploy": "npm run build",
    "deploy": "gh-pages -d dist",
    "android:build": "npm run android:sync && cd android && ./gradlew assembleRelease",
    "electron:release": "npm run generate-icons && cross-env ELECTRON=1 vite build && electron-builder --publish always",
    "electron:build:win": "npm run generate-icons && cross-env ELECTRON=1 vite build && electron-builder --win --publish never",
    "electron:build:mac": "npm run generate-icons && cross-env ELECTRON=1 vite build && electron-builder --mac --publish never",
    "electron:build:linux": "npm run generate-icons && cross-env ELECTRON=1 vite build && electron-builder --linux --publish never",
    "android:sync": "npm run build && npm run android:ensure && npx cap sync android",
    "android:ensure": "node -e \"const fs=require('fs'); const {spawnSync}=require('child_process'); if (!fs.existsSync('android')) { const r=spawnSync(process.platform==='win32'?'npx.cmd':'npx', ['cap', 'add', 'android']); process.exit(r.status); }\""
  },
  "build": {
    "appId": "com.animevault.app",
    "productName": "AnimeVault",
    "icon": "src/electron/.icon-ico/icon",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "src/electron/.icon-ico/icon.ico",
      "publisherName": "AnimeVault Team",
      "artifactName": "AnimeVault-Windows-${arch}.${ext}",
      "certificateFile": "${env.WIN_CERTIFICATE_FILE}",
      "certificatePassword": "${env.WIN_CERTIFICATE_PASSWORD}",
      "signingHashAlgorithms": [
        "sha256"
      ]
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "src/electron/.icon-ico/icon.icns",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "identity": "${env.MAC_IDENTITY}",
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "artifactName": "AnimeVault-macOS-${arch}.${ext}",
      "type": "distribution"
    },
    "linux": {
      "target": [
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "src/electron/.icon-ico/icon.png",
      "category": "AudioVideo",
      "maintainer": "AnimeVault Team",
      "artifactName": "AnimeVault-Linux-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true
    },
    "publish": [
      {
        "provider": "github",
        "releaseType": "release"
      }
    ],
    "npmRebuild": false
  },
  "dependencies": {
    "@neondatabase/auth": "^0.3.0-beta",
    "@neondatabase/serverless": "^1.1.0",
    "@noriginmedia/norigin-spatial-navigation": "^3.1.0",
    "@vidstack/react": "^1.12.13",
    "discord-rpc": "^4.0.1",
    "framer-motion": "^12.38.0",
    "hls.js": "^1.6.16",
    "lucide-react": "^1.16.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-icons": "^5.6.0",
    "react-router-dom": "^6.30.1",
    "vidstack": "^1.12.13",
    "electron-updater": "^6.3.9",
    "@capacitor/core": "^6.2.1",
    "bcryptjs": "^2.4.3"
  },
  "devDependencies": {
    "@types/react-router-dom": "^5.3.3",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^8.2.2",
    "electron": "^42.3.0",
    "electron-builder": "^24.13.3",
    "gh-pages": "^6.3.0",
    "vite": "^5.4.19",
    "cross-env": "^7.0.3",
    "wait-on": "^7.2.0",
    "@capacitor/android": "^6.2.1",
    "@capacitor/cli": "^6.2.1"
  },
  "engines": {
    "node": ">=22.12.0"
  }
}
