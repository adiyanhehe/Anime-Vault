{
  "name": "animevault",
  "private": true,
  "version": "0.1.0",
  "description": "The ultimate anime streaming experience",
  "author": "AnimeVault Team",
  "type": "module",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron:dev": "cross-env NODE_ENV=development concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:build": "cross-env ELECTRON=1 vite build && electron-builder",
    "predeploy": "npm run build",
    "deploy": "gh-pages -d dist",
    "lint": "echo 'No linter configured yet'"
  },
  "build": {
    "appId": "com.animevault.app",
    "productName": "AnimeVault",
    "icon": "src/electron/icon.png",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "win": {
      "target": [
        "nsis"
      ]
    },
    "mac": {
      "target": [
        "dmg"
      ]
    },
    "linux": {
      "target": [
        "AppImage"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true
    }
  },
  "dependencies": {
    "@neondatabase/auth": "^0.3.0-beta",
    "@neondatabase/serverless": "^1.1.0",
    "@noriginmedia/norigin-spatial-navigation": "^3.1.0",
    "@vidstack/react": "^1.12.13",
    "discord-rpc": "^4.0.1",
    "framer-motion": "^12.38.0",
    "hls.js": "^1.6.16",
    "lucide-react": "^1.16.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-icons": "^5.6.0",
    "react-router-dom": "^6.30.1",
    "vidstack": "^1.12.13"
  },
  "devDependencies": {
    "@types/react-router-dom": "^5.3.3",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^8.2.2",
    "electron": "^42.3.0",
    "electron-builder": "^24.13.3",
    "gh-pages": "^6.3.0",
    "vite": "^5.4.19",
    "cross-env": "^7.0.3",
    "wait-on": "^7.2.0"
  }
}
